generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Formation {
  id          String     @id @default(cuid())
  nom         String
  description String?
  prix        Float
  duree       String?
  tranches    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  candidats   Candidat[]
}

model Candidat {
  id          String    @id @default(cuid())
  matricule   String?   @unique
  nom         String
  postnom     String
  prenom      String?
  adresse     String?
  telephone   String
  email       String
  statut      String    @default("PENDING")
  formationId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  formation   Formation @relation(fields: [formationId], references: [id])
  payments    Payment[]
}

model Payment {
  id          String   @id @default(cuid())
  amount      Float
  datePayment DateTime @default(now())
  paymentMode String
  statut      String   @default("PENDING")
  captureUrl        String?
  numeroMobileMoney String?
  commentaire       String?
  adminId           String?
  candidatId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  candidat    Candidat @relation(fields: [candidatId], references: [id])
}

model CashEntry {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  accountNumber String?
  label         String
  amount        Float
  beneficiary   String?
  type          String   // ENTREE or SORTIE
  balance       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteSettings {
  id           String   @id @default("global")
  address      String   @default("Route Sake, Avenu Masisi, Q. Katindo, Goma / Nord-Kivu (RDC)")
  phonePrimary String   @default("+243 820 455 153")
  phoneSecondary String @default("+243 998 781 608")
  email        String   @default("contact@tcpsarl.cd")
  webUrl       String   @default("www.tcpsarl.cd")
  latitude     Float    @default(-1.5397)
  longitude    Float    @default(29.0213)
  updatedAt    DateTime @updatedAt
}
